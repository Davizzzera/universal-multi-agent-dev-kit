# =============================================================================
# Universal Multi-Agent Development Kit — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
._*
*.swp
*.swo

# -----------------------------------------------------------------------------
# Editor and IDE files
# -----------------------------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
.idea/
*.iml
*.sublime-project
*.sublime-workspace
*.code-workspace

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Environment and secrets
# -----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
*.cert
*.p12
*.pfx
*.secret
.credentials
.secrets/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/
.yarn/

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
out/
build/
dist/
*.tgz

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig
*.swp
*~

# -----------------------------------------------------------------------------
# Coverage and test reports
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
htmlcov/

# -----------------------------------------------------------------------------
# DO NOT IGNORE these directories
# -----------------------------------------------------------------------------
# !.agent/
# !docs/
